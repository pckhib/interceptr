{
  "name": "interceptr",
  "version": "0.0.0",
  "type": "module",
  "description": "Local HTTP proxy for mocking, intercepting and delaying API calls. Import OpenAPI/Swagger specs and control every endpoint from a browser UI — no code changes needed.",
  "author": "Patrick Hieber",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pckhib/interceptr.git"
  },
  "homepage": "https://github.com/pckhib/interceptr",
  "bugs": {
    "url": "https://github.com/pckhib/interceptr/issues"
  },
  "keywords": [
    "api",
    "api-proxy",
    "http-proxy",
    "reverse-proxy",
    "proxy-server",
    "api-mock",
    "mock-server",
    "mock-api",
    "http-mock",
    "api-interceptor",
    "http-interceptor",
    "request-interceptor",
    "response-mocking",
    "openapi",
    "openapi-mock",
    "openapi-3",
    "swagger",
    "swagger-mock",
    "api-testing",
    "integration-testing",
    "service-virtualization",
    "api-simulation",
    "latency-simulation",
    "delay-injection",
    "failure-injection",
    "chaos-testing",
    "frontend-development",
    "local-development",
    "developer-tools",
    "devtools",
    "nodejs",
    "cli"
  ],
  "bin": {
    "interceptr": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepack": "cp ../../README.md README.md",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@readme/openapi-parser": "^4.1.0",
    "hono": "^4.7.0",
    "js-yaml": "^4.1.1",
    "nanoid": "^5.0.9",
    "path-to-regexp": "^8.2.0"
  },
  "devDependencies": {
    "@interceptr/shared": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}